{
    "name": "toad.js",
    "version": "0.3.5",
    "description": "The TOAD JavaScript/TypeScript GUI Library",
    "author": "Mark-André Hopf <mhopf@mark13.org>",
    "license": "AGPL-3.0",
    "type": "module",
    "engines": {
        "npm": ">=10.5.0",
        "node": ">=21.7.1"
    },
    "files": [
        "README.md",
        "LICENSE",
        "package.json",
        "dist",
        "style"
    ],
    "exports": {
        "./*": {
            "import": "./dist/*.js",
            "types": "./dist/*.d.ts"
        }
    },
    "typesVersions": {
        "*": {
            "*": [
                "dist/*.d.ts"
            ]
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/markandre13/toad.js.git"
    },
    "scripts": {
        "build": "vite build",
        "start": "node docs/highlight.cjs && vite --open docs/index.dev.html",
        "test": "vitest --run",
        "lint": "tsgo -p tslint.json",
        "build:watch": "vite build --watch",
        "lint:watch": "tsgo --watch -p tslint.json",
        "test:watch": "vitest",
        "update": "npx npm-check-updates -u && npm install"
    },
    "devDependencies": {
        "@types/chai": "^5.2.3",
        "@types/node": "^26.1.0",
        "@types/prismjs": "^1.26.6",
        "@typescript/native-preview": "^7.0.0-dev.20260705.1",
        "@vitest/browser-playwright": "^4.1.9",
        "prismjs": "^1.30.0",
        "unplugin-dts": "^1.0.3",
        "vite": "^8.1.3",
        "vitest": "^4.1.9"
    },
    "dependencies": {
        "toad.jsx": "^0.1.6"
    }
}
